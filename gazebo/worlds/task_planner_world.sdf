        </visual>
        <inertial>
          <mass>0.2</mass>
          <inertia>
            <ixx>0.00003</ixx><iyy>0.00003</iyy><izz>0.00003</izz>
            <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
          </inertia>
        </inertial>
      </link>
    </model>

    <!-- ==================== Surfaces ==================== -->
    <!-- Shelves: 0.4m wide x 0.2m deep x 0.4m tall -->
    <!-- Tables: 0.4m wide x 0.4m deep x 0.3m tall -->

    <!-- shelf_a at grid (1,8) → world (4.25, -0.75) -->
    <model name="shelf_a">
      <static>true</static>
      <pose>4.25 -0.75 0.2 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>0.4 0.2 0.4</size></box></geometry>
        </collision>
