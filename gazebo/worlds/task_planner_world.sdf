    </model>

    <!-- ==================== Containers ==================== -->
    <!-- Open-top boxes: 0.3m x 0.3m x 0.2m, with 4 walls and no top -->

    <!-- container_a at grid (3,4) → world (2.25, -1.75) -->
    <model name="container_a">
      <static>true</static>
      <pose>2.25 -1.75 0.0 0 0 0</pose>
      <link name="link">
        <!-- Floor -->
        <collision name="floor_col">
          <pose>0 0 0.005 0 0 0</pose>
          <geometry><box><size>0.3 0.3 0.01</size></box></geometry>
        </collision>
        <visual name="floor_vis">
          <pose>0 0 0.005 0 0 0</pose>
          <geometry><box><size>0.3 0.3 0.01</size></box></geometry>
          <material>
            <ambient>0.02 0.71 0.83 1</ambient>
            <diffuse>0.02 0.71 0.83 1</diffuse>
          </material>
        </visual>
        <!-- Front wall -->
        <collision name="front_col">
          <pose>0.145 0 0.1 0 0 0</pose>
          <geometry><box><size>0.01 0.3 0.2</size></box></geometry>
        </collision>
        <visual name="front_vis">
          <pose>0.145 0 0.1 0 0 0</pose>
          <geometry><box><size>0.01 0.3 0.2</size></box></geometry>
          <material>
            <ambient>0.02 0.71 0.83 0.7</ambient>
            <diffuse>0.02 0.71 0.83 0.7</diffuse>
          </material>
        </visual>
        <!-- Back wall -->
        <collision name="back_col">
          <pose>-0.145 0 0.1 0 0 0</pose>
          <geometry><box><size>0.01 0.3 0.2</size></box></geometry>
        </collision>
        <visual name="back_vis">
          <pose>-0.145 0 0.1 0 0 0</pose>
          <geometry><box><size>0.01 0.3 0.2</size></box></geometry>
          <material>
            <ambient>0.02 0.71 0.83 0.7</ambient>
            <diffuse>0.02 0.71 0.83 0.7</diffuse>
          </material>
        </visual>
        <!-- Left wall -->
        <collision name="left_col">
          <pose>0 0.145 0.1 0 0 0</pose>
          <geometry><box><size>0.28 0.01 0.2</size></box></geometry>
        </collision>
        <visual name="left_vis">
          <pose>0 0.145 0.1 0 0 0</pose>
          <geometry><box><size>0.28 0.01 0.2</size></box></geometry>
          <material>
            <ambient>0.02 0.71 0.83 0.7</ambient>
            <diffuse>0.02 0.71 0.83 0.7</diffuse>
          </material>
        </visual>
        <!-- Right wall -->
        <collision name="right_col">
          <pose>0 -0.145 0.1 0 0 0</pose>
          <geometry><box><size>0.28 0.01 0.2</size></box></geometry>
        </collision>
        <visual name="right_vis">
          <pose>0 -0.145 0.1 0 0 0</pose>
