    <!-- container_b at grid (7,7) → world (3.75, -3.75) -->
    <model name="container_b">
      <static>true</static>
      <pose>3.75 -3.75 0.0 0 0 0</pose>
      <link name="link">
        <!-- Floor -->
        <collision name="floor_col">
          <pose>0 0 0.005 0 0 0</pose>
          <geometry><box><size>0.3 0.3 0.01</size></box></geometry>
        </collision>
