          <geometry><box><size>0.4 0.2 0.4</size></box></geometry>
          <material>
            <ambient>0.55 0.36 0.96 1</ambient>
            <diffuse>0.55 0.36 0.96 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- shelf_b at grid (3,8) → world (4.25, -1.75) -->
    <model name="shelf_b">
      <static>true</static>
      <pose>4.25 -1.75 0.2 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>0.4 0.2 0.4</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.4 0.2 0.4</size></box></geometry>
          <material>
            <ambient>0.66 0.33 0.97 1</ambient>
            <diffuse>0.66 0.33 0.97 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- table_1 at grid (5,5) → world (2.75, -2.75) -->
    <model name="table_1">
      <static>true</static>
      <pose>2.75 -2.75 0.15 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>0.4 0.4 0.3</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.4 0.4 0.3</size></box></geometry>
          <material>
            <ambient>0.85 0.47 0.02 1</ambient>
            <diffuse>0.85 0.47 0.02 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- table_2 at grid (7,2) → world (1.25, -3.75) -->
    <model name="table_2">
      <static>true</static>
      <pose>1.25 -3.75 0.15 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>0.4 0.4 0.3</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.4 0.4 0.3</size></box></geometry>
          <material>
            <ambient>0.71 0.33 0.04 1</ambient>
            <diffuse>0.71 0.33 0.04 1</diffuse>
          </material>
        </visual>
